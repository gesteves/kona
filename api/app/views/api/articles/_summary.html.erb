<%#
  Article summary card for the trending section. Local: `article`. Ported from the static site's
  partials/article/_summary.html.erb — prose body via the minimal renderer; no cover image.
%>
<article class="entry entry--summary" id="entry-<%= article.sys.id.parameterize %>" aria-labelledby="hed-<%= article.sys.id.parameterize %>">
  <header class="entry__header">
    <p class="entry__meta"
      data-controller="publish-date"
      data-publish-date-datetime-value="<%= DateTime.parse(article.published_at).iso8601 %>"
      data-publish-date-entry-type-value="<%= article.entry_type %>"
      data-publish-date-draft-value="<%= article.draft %>">
      <span class="entry__highlight" data-publish-date-target="badge" hidden><%= raw icon_svg("classic", "regular", "sparkles") %> New</span>
      <span>
        <span data-publish-date-target="clock" hidden><%= raw clock_icon_svg(DateTime.parse(article.published_at)) %></span>
        <span data-publish-date-target="calendar"><%= raw icon_svg("classic", "light", "calendar") %></span>
        <%= article_permalink_timestamp(article) %>
      </span>
    </p>
    <h4 class="entry__hed" id="hed-<%= article.sys.id.parameterize %>">
      <%= link_to raw(smartypants(article.title)), article.path %>
    </h4>
  </header>
  <div class="entry__body">
    <%= raw render_summary_body(article.summary) %>
  </div>
</article>
