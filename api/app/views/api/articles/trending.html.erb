<%#
  The home page's "Trending Articles" section, served as a live-update fragment that the static
  site swaps in. The outer <section> carries the live-update attributes so it keeps refreshing
  after the swap (and on visibilitychange).
%>
<section class="collection collection--halves" id="trending-articles" data-nosnippet data-controller="live-update" data-live-update-url-value="<%= live_update_url %>" data-action="visibilitychange@document->live-update#handleVisibilityChange">
  <h3 class="collection__heading">Trending Articles</h3>
  <ol class="collection__list">
    <% @articles.each do |article| %>
      <li class="collection__item">
        <%= render "summary", article: article %>
      </li>
    <% end %>
  </ol>
</section>
