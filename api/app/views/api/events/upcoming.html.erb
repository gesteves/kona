<%#
  The races widget, served as a live-update fragment the static site swaps in. The outer
  wrapper carries the live-update attributes; it's display:contents, so the inner <section>s
  lay out directly in the page grid. Off race day it holds a single "Upcoming Races" section
  (the first event featured — expanded card + inline race-day weather — when within 10 days).
  On race day, today's race gets its own "Today's Race" section with that weather, and the
  remaining races follow under "Upcoming Races".
%>
<div class="collection-group" data-nosnippet data-controller="live-update" data-live-update-url-value="<%= live_update_url %>" data-action="visibilitychange@document->live-update#handleVisibilityChange">
  <% if @todays_race %>
    <section class="collection collection--single collection--has-featured" id="todays-race">
      <h3 class="collection__heading">Today’s Race</h3>
      <ol class="collection__list">
        <li class="collection__item">
          <%# show_timestamp: false — the "Today's Race" heading already says it's today. %>
          <%= render "event", event: @todays_race, featured: true, event_weather: @event_weather, show_timestamp: false %>
        </li>
      </ol>
    </section>
    <% if @other_races.present? %>
      <section class="collection collection--<%= event_collection_variant(@other_races.size, featured: false) %>" id="upcoming-races">
        <h3 class="collection__heading">Upcoming Races</h3>
        <ol class="collection__list">
          <% @other_races.each do |event| %>
            <li class="collection__item">
              <%= render "event", event: event, featured: false, event_weather: nil %>
            </li>
          <% end %>
        </ol>
      </section>
    <% end %>
  <% else %>
    <section class="collection collection--<%= event_collection_variant %><%= " collection--has-featured" if @featured %>" id="upcoming-races">
      <h3 class="collection__heading">Upcoming Races</h3>
      <ol class="collection__list">
        <% @upcoming.each do |event| %>
          <% featured = event.sys&.id == @featured&.sys&.id %>
          <li class="collection__item">
            <%= render "event", event: event, featured: featured, event_weather: (featured ? @event_weather : nil) %>
          </li>
        <% end %>
      </ol>
    </section>
  <% end %>
</div>
