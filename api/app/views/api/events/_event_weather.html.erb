<%#
  Race-day weather block for the featured event, rendered inline in the upcoming-races section.
  Takes `event_weather` (an EventWeatherPresenter) as a local. Moved here from the former
  standalone /api/weather/event view.
%>
<%
  event = event_weather.event
  event_day = event_weather.forecast_day
  event_forecast = event_weather.forecast
%>
<section class="event__weather" aria-labelledby="weather-hed-<%= event.sys.id.parameterize %>" data-nosnippet>
  <h5 class="event__weather-heading" id="weather-hed-<%= event.sys.id.parameterize %>">Race Day Weather</h5>
  <div class="event__weather-stats">
    <% if event.location.present? %>
      <div class="event__weather-stat-group">
        <span class="event__weather-stat"><span class="sr-only">Location:</span> <%= raw icon_svg("classic", "light", "location-dot") %> <%= event.location_label.presence || format_location(event.location) %></span>
        <% if event.location.elevation.present? %>
          <span class="event__weather-stat" title="Elevation"><span class="sr-only">Elevation:</span> <%= raw icon_svg("classic", "light", "mountains") %> <%= format_elevation(event.location.elevation, true) %></span>
        <% end %>
      </div>
    <% end %>
    <% if event_forecast.present? %>
      <div class="event__weather-stat-group">
        <span class="event__weather-stat"><%= raw icon_svg("classic", "light", weather_icon(event_forecast.condition_code, :day)) %> <%= format_condition(event_forecast.condition_code) %></span>
      </div>
      <% if event_forecast.temperature_min.present? || event_forecast.temperature_max.present? %>
      <div class="event__weather-stat-group">
        <span class="event__weather-stat">
          <%= raw icon_svg("classic", "light", "temperature-low") %>
          <%= format_temperature(event_forecast.temperature_min) %>
          low
        </span>
        <span class="event__weather-stat">
          <%= raw icon_svg("classic", "light", "temperature-high") %>
          <%= format_temperature(event_forecast.temperature_max) %>
          high
        </span>
      </div>
    <% end %>
      <% if event_forecast.humidity.present? || event_forecast.precipitation_chance.present? %>
      <div class="event__weather-stat-group">
        <% if event_forecast.humidity.present? %>
          <span class="event__weather-stat">
            <%= raw icon_svg("classic", "light", "droplet-percent") %>
            <%= number_to_percentage(event_forecast.humidity * 100, precision: 0) %>
            humidity
          </span>
        <% end %>
        <% if event_forecast.precipitation_chance.present? %>
          <span class="event__weather-stat">
            <%= raw icon_svg("classic", "light", "raindrops") %>
            <%= number_to_percentage(event_forecast.precipitation_chance * 100, precision: 0) %>
            chance of <%= event_weather.precipitation_label %>
        <% end %>
      </div>
    <% end %>
      <% if event_forecast.wind_speed.present? && event_forecast.wind_direction.present? %>
      <div class="event__weather-stat-group">
        <span class="event__weather-stat">
          <span class="event__weather-wind-direction" style="--wind-direction: <%= event_forecast.wind_direction %>;" title="<%= wind_direction(event_forecast.wind_direction) %>">
            <%= raw icon_svg("classic", "light", "arrow-down") %>
          </span>
          <%= format_wind_speed_range(event_forecast.wind_speed, event_forecast.wind_speed_max) %>
          wind
          <span class="sr-only">from the <%= wind_direction(event_forecast.wind_direction) %></span>
        </span>
        <% if show_gusts?(event_forecast.wind_speed, event_forecast.wind_gust_speed_max) %>
          <span class="event__weather-stat">
            <%= raw icon_svg("classic", "light", "wind") %>
            <%= format_wind_speed(event_forecast.wind_gust_speed_max) %>
            gusts
          </span>
        <% end %>
      </div>
    <% end %>
    <% end %>
    <% bay = event_weather.bay %>
    <% if bay.present? %>
      <div class="event__weather-stat-group">
        <span class="event__weather-stat">
          <%= raw icon_svg("classic", "light", "water-temperature") %>
          <%= format_temperature(bay.water_temp_c) %>
        </span>
        <span class="event__weather-stat">
          <span class="event__weather-wind-direction" style="--wind-direction: <%= (bay.current_bearing_deg + 180) % 360 %>;" title="<%= wind_direction(bay.current_bearing_deg) %>">
            <%= raw icon_svg("classic", "light", "arrow-down") %>
          </span>
          <%= format_bay_current_speed(bay.current_speed_ms) %>
          current
          <span class="sr-only">toward the <%= wind_direction(bay.current_bearing_deg) %></span>
        </span>
      </div>
    <% end %>
    <% if event.aqi.present? %>
      <div class="event__weather-stat-group">
        <span class="event__weather-stat"><%= raw icon_svg("classic", "light", aqi_icon(event.aqi.aqi)) %> <abbr title="Air Quality Index">AQI</abbr> <%= event.aqi.aqi %> &middot; <%= event.aqi.description %></span>
      </div>
    <% end %>
    <% if event_day&.sunrise.present? || event_day&.sunset.present? %>
      <div class="event__weather-stat-group">
        <% if event_weather.sunrise.present? && event_weather.time_zone_id.present? %>
          <span class="event__weather-stat" title="Sunrise"><span class="sr-only">Sunrise:</span> <%= raw icon_svg("classic", "light", "sunrise") %> <%= raw time_with_meridiem_abbr(event_weather.sunrise, event_weather.time_zone_id) %></span>
        <% end %>
        <% if event_weather.sunset.present? && event_weather.time_zone_id.present? %>
          <span class="event__weather-stat" title="Sunset"><span class="sr-only">Sunset:</span> <%= raw icon_svg("classic", "light", "sunset") %> <%= raw time_with_meridiem_abbr(event_weather.sunset, event_weather.time_zone_id) %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
