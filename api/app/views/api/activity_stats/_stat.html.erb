<div class="stats__stat">
  <span class="stats__meta"><% if local_assigns[:icon] %><%= raw icon_svg("classic", "light", icon) %> <% end %><%= top %></span>
  <span class="stats__number"><%= value %><% if local_assigns[:unit] %><span class="stats__unit"><%= unit %></span><% end %></span>
  <span class="stats__meta"><%= bottom %><% if local_assigns[:info_url] %> <a href="<%= info_url %>" target="_blank" rel="nofollow noopener"><%= raw icon_svg("classic", "light", "circle-info") %></a><% end %></span>
</div>
