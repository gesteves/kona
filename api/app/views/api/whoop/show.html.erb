<section data-nosnippet class="stats stats--has-three" data-controller="live-update" data-live-update-url-value="<%= live_update_url %>" data-action="visibilitychange@document->live-update#handleVisibilityChange" aria-labelledby="hed-whoop">
  <h3 class="stats__heading" id="hed-whoop"><%= raw whoop_heading %></h3>
  <div class="stats__container">
    <%= render "api/activity_stats/stat", icon: "moon",                 top: "Sleep",    value: whoop_sleep_score,    unit: "%",   bottom: whoop_sleep_label %>
    <%= render "api/activity_stats/stat", icon: whoop_recovery_icon,    top: "Recovery", value: whoop_recovery_score, unit: "%",   bottom: whoop_recovery_label %>
    <%= render "api/activity_stats/stat", icon: "fire-flame-curved",    top: "Strain",   value: whoop_strain_score,   unit: "/21", bottom: whoop_strain_label %>
  </div>
  <% if ENV["WHOOP_REFERRAL_URL"].present? %>
    <p class="stats__footer">
      <%= link_to "Join Whoop <i>and</i> get one month free".html_safe, ENV["WHOOP_REFERRAL_URL"], target: "_blank", rel: "nofollow noopener sponsored" %>
    </p>
  <% end %>
</section>
