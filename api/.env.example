# Redis connection, shared with the web app. Use rediss:// for TLS (e.g. Upstash).
REDIS_URL=

# Intervals.icu credentials, used to fetch activity stats.
ICU_ATHLETE_ID=
ICU_API_KEY=

# Font Awesome API token, used to fetch icon SVGs.
FONT_AWESOME_API_TOKEN=

# Whoop OAuth app credentials, used to fetch sleep/recovery/strain. The redirect URI
# must be registered in the Whoop developer dashboard (e.g. https://<your-app-host>/whoop/callback).
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=

# HTTP Basic Auth credentials gating GET /whoop/auth, so only you can connect a Whoop account.
WHOOP_AUTH_USERNAME=
WHOOP_AUTH_PASSWORD=

# Google Maps API key. Reverse-geocodes the location into a timezone/country/elevation,
# and powers the Google Air Quality (AQI fallback) and Pollen lookups for the weather widget.
GOOGLE_API_KEY=

# Bearer token required by POST /location to set the current location.
API_TOKEN=

# Apple WeatherKit credentials, used to fetch the weather. WEATHERKIT_PRIVATE_KEY is the
# base64-encoded .p8 EC private key.
WEATHERKIT_KEY_ID=
WEATHERKIT_TEAM_ID=
WEATHERKIT_SERVICE_ID=
WEATHERKIT_PRIVATE_KEY=

# Contentful (read API), used by the weather widget to spot today's race and to sync
# standard.site records.
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=

# HMAC secret for verifying Contentful webhook requests (POST /api/webhooks/contentful).
# 64 chars matching /^[0-9a-zA-Z+/=_-]+$/; set the same value in the Contentful webhook's
# request-verification settings. Without it the webhook endpoint returns 401.
CONTENTFUL_WEBHOOK_SECRET=

# Public site root URL (no trailing slash), used as the standard.site publication `url`.
# NEVER hardcode the production hostname; this is environment-specific.
SITE_URL=

######################################
# The variables below are all OPTIONAL
######################################

# Comma-separated allowlist of Host headers accepted in production (DNS-rebinding / Host-header
# protection). List every host the origin is reached by — the custom API host plus the .fly.dev
# fallback if the proxy uses it, e.g. "<your-api-host>,<your-app>.fly.dev". NEVER hardcode the
# production hostname. When unset, all hosts are accepted (host authorization stays off). The
# /up health check is always exempt. Only consulted in production.
ALLOWED_HOSTS=

# Font Awesome version to fetch icons for. Defaults to 7.3.0.
FONT_AWESOME_VERSION=

# Whoop referral link shown under the Whoop widget. Hidden if unset.
WHOOP_REFERRAL_URL=

# TrainerRoad calendar (iCalendar) feed, used to decide whether today is a rest day.
TRAINERROAD_CALENDAR_URL=

# PurpleAir API key, used for the weather widget's AQI (nearest US sensor). Falls back to
# the Google Air Quality API when unset or no sensor is nearby.
PURPLEAIR_API_KEY=

# Current location as a "latitude,longitude" pair. Overrides the value set via
# POST /location. Requires GOOGLE_API_KEY for timezone lookups.
LOCATION=

# Fallback timezone used when no location/geocoding is available. Defaults to America/Denver.
TIME_ZONE=

# Publishes the blog to the AT Protocol as standard.site records (webhook-driven, plus the
# standard_site:backfill rake task). Use a Bluesky app password, not your account password.
# When unset, the standard.site webhook + endpoint no-op and the site omits verification markup.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# Optional PDS host; defaults to https://bsky.social.
BLUESKY_PDS_URL=

# Bugsnag project API key for error reporting. Only production notifies; unset locally
# and in CI, where exception reporting is a no-op.
BUGSNAG_API_KEY=
