# Redis connection, shared with the web app. Use rediss:// for TLS (e.g. Upstash).
REDIS_URL=

# Intervals.icu credentials, used to fetch activity stats.
ICU_ATHLETE_ID=
ICU_API_KEY=

# Font Awesome API token, used to fetch icon SVGs.
FONT_AWESOME_API_TOKEN=

######################################
# The variables below are all OPTIONAL
######################################

# Font Awesome version to fetch icons for. Defaults to 7.2.0.
FONT_AWESOME_VERSION=

# Absolute URL the embedded markup should refetch from on visibilitychange.
# Defaults to the request's own scheme/host/path; set this when the public URL
# differs from the origin host (e.g. behind CloudFront).
ACTIVITY_STATS_URL=
