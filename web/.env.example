######################################
# The variables below are all REQUIRED
######################################

# Retrieves blog content from Contentful.
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=

# Retrieves icons from the Font Awesome GraphQL API; requires a Pro account.
FONT_AWESOME_API_TOKEN=

# Used for caching. Use rediss:// for TLS (e.g. Upstash).
REDIS_URL=

# Base URL of the kona-api service, which serves the embedded activity-stats markup.
KONA_API_URL=

# Shared bearer token the /api/* proxy (netlify/functions/api-proxy.mts) injects on every
# upstream request; must match the kona-api app's API_TOKEN. Set it in Netlify's env too, or
# every widget 401s at the origin and collapses on the site.
API_TOKEN=

######################################
# The variables below are all OPTIONAL
######################################

# Used for retrieving robots.txt directives to block AI scrapers.
DARK_VISITORS_ACCESS_TOKEN=

# Used to fetch images from Cloudfront.
CLOUDFRONT_DOMAIN=
