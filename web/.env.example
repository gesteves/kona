######################################
# The variables below are all REQUIRED
######################################

# Retrieves blog content from Contentful.
CONTENTFUL_SPACE=
CONTENTFUL_TOKEN=

# Retrieves icons from the Font Awesome GraphQL API; requires a Pro account.
FONT_AWESOME_API_TOKEN=

# Used for caching. Use rediss:// for TLS (e.g. Upstash).
REDIS_URL=

# Base URL of the kona-api service, which serves the embedded activity-stats markup.
KONA_API_URL=

######################################
# The variables below are all OPTIONAL
######################################

# URL of a Netlify build hook used to automatically redeploy the site hourly.
BUILD_HOOK_URL=

# Used for retrieving robots.txt directives to block AI scrapers.
DARK_VISITORS_ACCESS_TOKEN=


# Used for fetching traffic data for various purposes.
PLAUSIBLE_API_KEY=
PLAUSIBLE_SITE_ID=

# Used to fetch images from Cloudfront.
CLOUDFRONT_DOMAIN=

# Publishes the blog to the AT Protocol as standard.site records. Use a Bluesky
# app password (Settings → App passwords), not your account password. Records are
# only written during production builds (CONTEXT=production).
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# Optional; defaults to https://bsky.social.
BLUESKY_PDS_URL=
