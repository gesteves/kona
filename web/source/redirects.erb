<%# Plausible analytics first-party proxy (/plsbl/*). Emitted first so a catch-all %>
<%# redirect from Contentful (below) can't shadow these rewrites. See site_helpers.rb. %>
<% plausible_proxy_redirects.each do |redirect| %>
<%= redirect[:from] %> <%= redirect[:to] %> <%= redirect[:status] %>
<% end %>
<% data.articles.reject(&:draft).each do |article| %>
/id/<%= article.sys.id %>/ <%= url_for article.path %> 301
<% end %>
<% data.pages.reject(&:draft).each do |page| %>
/id/<%= page.sys.id %>/ <%= url_for page.path %> 301
<% end %>
<% data.redirects.each do |redirect| %>
<%= redirect.from %> <%= redirect.to %> <%= redirect.status %><%= "!" if redirect.from.match? /^https?:\/\// %>
<% end %>
