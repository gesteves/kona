<%# Loading skeleton for the races widget. The wrapper carries the live-update attributes; %>
<%# it's display:contents, so the section lays out directly in the page grid. The API swaps %>
<%# the whole wrapper in on connect — a single "Upcoming Races" section, or a "Today's Race" %>
<%# + "Upcoming Races" pair on race day — and removes it on an empty response (no upcoming %>
<%# races). See api/app/views/api/events/. %>
<div class="collection-group" data-nosnippet data-controller="live-update" data-live-update-url-value="/api/events/upcoming" data-live-update-fetch-on-connect-value="true" data-action="visibilitychange@document->live-update#handleVisibilityChange">
  <section class="collection collection--thirds" id="upcoming-races">
    <h3 class="collection__heading">Upcoming Races</h3>
    <ol class="collection__list">
      <% 3.times do %>
        <li class="collection__item">
          <%= partial 'partials/placeholders/entry_skeleton', locals: { lines: 4 } %>
        </li>
      <% end %>
    </ol>
  </section>
</div>
