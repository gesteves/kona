<head>
  <%= partial 'partials/meta' %>
  <%= partial 'partials/open_graph_and_social' %>
  <%= partial 'partials/schema/article', locals: { article: content } if defined?(content) && content.entry_type == 'Article' && !content.draft %>
  <%= partial 'partials/schema/organization' %>
  <%= partial 'partials/schema/breadcrumb' if defined?(content) && content.entry_type == 'Article' && !content.draft %>
  <% if data.respond_to?(:standard_site) && data.standard_site&.publication_uri.present? %>
    <link rel="site.standard.publication" href="<%= data.standard_site.publication_uri %>">
    <% if defined?(content) && %w[Article Short].include?(content.entry_type) && !content.draft && data.standard_site.did.present? %>
      <link rel="site.standard.document" href="at://<%= data.standard_site.did %>/site.standard.document/<%= content.sys.id %>">
    <% end %>
  <% end %>
  <link rel="canonical" href="<%= canonical_url %>">
  <link rel="alternate" type="application/atom+xml" title="<%= sanitize(data.site.meta_title) %>" href="<%= full_url("/feed.xml") %>" />
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <% if data.site.logo.present? %>
    <link rel="apple-touch-icon" href="<%= site_icon_url(w: 180) %>">
    <link rel="manifest" href="/manifest.json">
  <% end %>
  <%= javascript_include_tag 'site', defer: 'defer', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'site', 'data-turbo-track': 'reload' %>
  <%= stylesheet_link_tag 'print', media: 'print', 'data-turbo-track': 'reload' %>
  <%= yield_content :assets %>
  <%= partial 'partials/analytics' %>
</head>
