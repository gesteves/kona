  <%# sets capture_pageview to 'history_change', so it tracks Turbo navigations natively. %>
  <%# api_host is our reverse proxy (subdomain, kept in env, never hardcoded); ui_host points %>
  <%# at PostHog's real app so the toolbar/links resolve. See lib/helpers/site_helpers.rb. %>
