<% whoop_url = "/api/whoop" %>
<%# Loading skeleton for the /whoop markup. The live-update controller swaps in the %>
<%# real markup on connect (or removes this section if there's no Whoop data). %>
<section data-nosnippet class="stats stats--has-three" data-controller="live-update" data-live-update-url-value="<%= whoop_url %>" data-live-update-fetch-on-connect-value="true" data-action="visibilitychange@document->live-update#handleVisibilityChange" aria-labelledby="hed-whoop">
  <h3 class="stats__heading" id="hed-whoop">Latest Metrics <i>from</i> <a href="https://www.whoop.com" target="_blank" rel="nofollow noopener">Whoop</a></h3>
  <div class="stats__container">
    <%= partial 'partials/placeholders/stat_skeleton', locals: { icon: 'moon',              top: 'Sleep' } %>
    <%= partial 'partials/placeholders/stat_skeleton', locals: { icon: 'person-meditating', top: 'Recovery' } %>
    <%= partial 'partials/placeholders/stat_skeleton', locals: { icon: 'fire-flame-curved', top: 'Strain' } %>
  </div>
  <p class="stats__footer">
    <wa-skeleton class="stats-footer-skeleton" effect="sheen"></wa-skeleton>
  </p>
</section>
