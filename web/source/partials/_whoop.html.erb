<% whoop_url = "#{ENV.fetch('KONA_API_URL', 'https://kona-api.fly.dev')}/whoop" %>
<%# Empty live-update shell: the Whoop markup (or nothing, when there's no data) is %>
<%# fetched from the API on connect and swapped in. Keep it free of inner whitespace %>
<%# so `.stats:empty` collapses it until content arrives. %>
<section data-nosnippet class="stats stats--has-three" data-controller="live-update" data-live-update-url-value="<%= whoop_url %>" data-live-update-fetch-on-connect-value="true" data-action="visibilitychange@document->live-update#handleVisibilityChange"></section>
