<div class="home" aria-labelledby="hed">
  <section class="home__intro">
    <h2 class="home__headline" id="hed">
      <%= smartypants(content.title) %>
    </h2>
    <div class="home__body">
      <%= render_home_body(content.body) %>
    </div>
  </section>
  <%= partial 'partials/placeholders/stats' %>
  <% recent = recent_articles %>
  <% if recent.present? %>
    <%= partial 'partials/collection', locals: { title: "Recent Articles", items: recent, variant: "halves" } %>
  <% end %>
  <%= partial 'partials/placeholders/whoop' %>
  <%# Exclude the Recent Articles shown above so trending doesn't repeat them; ids sorted for a %>
  <%# canonical, cache-friendly path. Falls back to the bare endpoint when there's nothing to drop. %>
  <% trending_exclude_ids = (recent || []).map { |a| a.sys.id }.uniq.sort %>
  <% trending_url = trending_exclude_ids.any? ? "/api/articles/trending/exclude/#{trending_exclude_ids.join(',')}" : "/api/articles/trending" %>
  <%= partial 'partials/placeholders/trending', locals: { url: trending_url } %>
  <%= partial 'partials/placeholders/weather' %>
  <% if data.events.present? %>
    <%= partial 'partials/upcoming_races' %>
  <% end %>
</div>
