<%= partial 'partials/article/short', locals: { article: content, indexable: true } %>
<%= partial 'partials/share', locals: { article: content } %>
<%# Shorts have no event, so they always show the semantically-related "You May Also Like" widget. %>
<%= partial 'partials/placeholders/related', locals: { url: "/api/articles/related/#{content.sys.id}" } %>
<%# Exclude only this entry so trending doesn't repeat it. %>
<%= partial 'partials/placeholders/trending', locals: { url: "/api/articles/trending/#{content.sys.id}" } %>
