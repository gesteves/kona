<%= partial 'partials/article/full', locals: { article: content } %>
<%= partial 'partials/share', locals: { article: content } %>
<%# Show race reports from the same event when there are any; otherwise show the semantically- %>
<%# related "You May Also Like" widget (served by the API). They're mutually exclusive so the two %>
<%# sections never duplicate each other. %>
<% if related_race_reports(content).present? %>
  <%= partial 'partials/race_reports', locals: { article: content } %>
<% else %>
  <%= partial 'partials/placeholders/related', locals: { url: "/api/articles/related/#{content.sys.id}" } %>
<% end %>
<%# Exclude only this article so trending doesn't repeat it. %>
<%= partial 'partials/placeholders/trending', locals: { url: "/api/articles/trending/#{content.sys.id}" } %>
