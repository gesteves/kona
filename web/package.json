{
  "scripts": {
    "build": "esbuild source/javascripts/stimulus/index.js --bundle --minify --target=es2020 --outfile=source/javascripts/site.js",
    "watch": "esbuild source/javascripts/stimulus/index.js --bundle --target=es2020 --outfile=source/javascripts/site.js --watch",
    "lint:scss": "stylelint \"source/stylesheets/**/*.scss\"",
    "lint:scss:fix": "stylelint \"source/stylesheets/**/*.scss\" --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "pagefind": "pagefind --site build",
    "fix:degrees": "node --env-file=.env scripts/fix-degrees.js"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.23",
    "@netlify/functions": "^5.3.0",
    "@vercel/og": "^0.11.1",
    "@web.awesome.me/webawesome-pro": "^3.7.0",
    "esbuild": "^0.28.1",
    "node-fetch": "^3.3.2",
    "pagefind": "^1.5.2",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "contentful-migration": "^5.0.0",
    "prettier": "^3.8.5",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.2.0"
  }
}
